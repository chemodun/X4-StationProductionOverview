<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Station_Production_Overview" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <cues>

    <cue name="Init" instantiate="false" version="1">
      <cues>

        <!-- == Config initialisation == -->
        <!-- Loads player.entity.$stationProductionOverview, creating it with defaults if
             absent. Sets $config as a local alias. Callers must remove_value
             $config when done. -->
        <library name="Get_Config" purpose="include_actions" version="3">
          <actions>
            <do_if value="@player.entity.$stationProductionOverview == null">
              <set_value name="player.entity.$stationProductionOverview" exact="table[
                $version                       = 3,
                $dataRefreshInterval           = 3,
                $ignoreNoResources             = false,
                $ignoreWaitStore               = false,
                $showErrorsAsSubrow            = true,
                $syncStationProductionSettings = false,
              ]" />
            </do_if>
            <!-- v1 → v2: add error-display settings to existing saves -->
            <do_if value="@player.entity.$stationProductionOverview.$version lt 2">
              <do_if value="player.entity.$stationProductionOverview.$dataRefreshInterval? == false">
                <set_value name="player.entity.$stationProductionOverview.$dataRefreshInterval" exact="3" />
              </do_if>
              <set_value name="player.entity.$stationProductionOverview.$ignoreNoResources" exact="false" />
              <set_value name="player.entity.$stationProductionOverview.$ignoreWaitStore" exact="false" />
              <set_value name="player.entity.$stationProductionOverview.$showErrorsAsSubrow" exact="true" />
              <set_value name="player.entity.$stationProductionOverview.$version" exact="2" />
            </do_if>
            <!-- v2 → v3: add sync setting -->
            <do_if value="@player.entity.$stationProductionOverview.$version lt 3">
              <set_value name="player.entity.$stationProductionOverview.$syncStationProductionSettings" exact="false" />
              <set_value name="player.entity.$stationProductionOverview.$version" exact="3" />
            </do_if>
            <set_value name="$config" exact="player.entity.$stationProductionOverview" />
          </actions>
        </library>

        <!-- == Options menu registration == -->
        <cue name="Register_Menu" instantiate="true" version="1">
          <conditions>
            <event_cue_signalled cue="md.Simple_Menu_API.Reloaded" />
          </conditions>
          <actions>
            <include_actions ref="Get_Config" />
            <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu"
              param="table[
                $id      = 'station_production_overview_options',
                $columns = 12,
                $title   = {1972092416, 90001},
                $onOpen  = Options_Menu_Open,
              ]" />
            <remove_value name="$config" />
          </actions>
        </cue>

        <!-- == Options menu content == -->
        <cue name="Options_Menu_Open" instantiate="true" version="2">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <include_actions ref="Get_Config" />
            <include_actions ref="Menu_Section_Performance" />
            <include_actions ref="Menu_Section_ModuleErrors" />
            <include_actions ref="Menu_Section_Interoperability" />
            <remove_value name="$config" />
          </actions>
        </cue>

        <!-- == Performance section: data refresh interval == -->
        <library name="Menu_Section_Performance" purpose="include_actions" version="1">
          <actions>
            <run_actions ref="Add_Title_Row">
              <param name="title" value="{1972092416, 90100}" />
            </run_actions>
            <run_actions ref="Add_Slider">
              <param name="id" value="'dataRefreshInterval'" />
              <param name="text" value="{1972092416, 90101}" />
              <param name="min" value="1" />
              <param name="max" value="10" />
              <param name="step" value="1" />
              <param name="suffix" value="' ticks'" />
              <param name="colSpan" value="12" />
              <param name="data" value="@$config" />
            </run_actions>
          </actions>
        </library>

        <!-- == Module Errors section: ignore + display mode == -->
        <library name="Menu_Section_ModuleErrors" purpose="include_actions" version="1">
          <actions>
            <include_actions ref="Add_Empty_Row" />
            <run_actions ref="Add_Title_Row">
              <param name="title" value="{1972092416, 90200}" />
            </run_actions>
            <!-- Show errors as sub-row toggle -->
            <run_actions ref="Add_CheckBox">
              <param name="id" value="'showErrorsAsSubrow'" />
              <param name="col" value="1" />
              <param name="textColSpan" value="11" />
              <param name="text" value="{1972092416, 90211}" />
              <param name="data" value="@$config" />
            </run_actions>
            <include_actions ref="Add_Empty_Row" />
            <!-- "Ignore errors:" label (non-selectable) -->
            <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
            <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
              param="table[
                $col     = 1,
                $colSpan = 12,
                $halign  = 'left',
                $text    = {1972092416, 90220},
              ]" />
            <!-- Two ignore checkboxes side by side -->
            <run_actions ref="Add_CheckBox">
              <param name="id" value="'ignoreNoResources'" />
              <param name="col" value="1" />
              <param name="textColSpan" value="5" />
              <param name="text" value="{1001, 8431}" />
              <param name="data" value="@$config" />
            </run_actions>
            <run_actions ref="Add_CheckBox">
              <param name="id" value="'ignoreWaitStore'" />
              <param name="col" value="7" />
              <param name="textColSpan" value="5" />
              <param name="text" value="{1001, 8432}" />
              <param name="data" value="@$config" />
            </run_actions>
          </actions>
        </library>

        <!-- == Generic checkbox handler == -->
        <cue name="Handle_Checkbox_Changed" instantiate="true" version="1">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <include_actions ref="Get_Config" />
            <set_value name="$valueId" exact="event.param.$echo.$valueId" />
            <set_value name="$config.{@$valueId}" exact="event.param.$checked" />
            <do_if value="@$valueId == '$syncStationProductionSettings'">
              <include_actions ref="Handle_Sync_Changed" />
            </do_if>
            <do_else>
              <include_actions ref="Propagate_Sync" />
            </do_else>
            <remove_value name="$valueId" />
            <remove_value name="$config" />
            <raise_lua_event name="'SPO.ConfigChanged'" />
          </actions>
        </cue>

        <!-- == Generic slider handler == -->
        <cue name="Handle_Slider_Changed" instantiate="true" version="2">
          <conditions>
            <event_cue_signalled />
          </conditions>
          <actions>
            <include_actions ref="Get_Config" />
            <set_value name="$valueId" exact="event.param.$echo.$valueId" />
            <set_value name="$config.{@$valueId}" exact="event.param.$value" />
            <include_actions ref="Propagate_Sync" />
            <remove_value name="$valueId" />
            <remove_value name="$config" />
            <raise_lua_event name="'SPO.ConfigChanged'" />
          </actions>
        </cue>

        <!-- == Sync propagation helper == -->
        <!-- Requires $valueId and $config to be set by the caller.             -->
        <!-- Mirrors the changed value to PST config if sync is enabled.        -->
        <library name="Propagate_Sync" purpose="include_actions" version="1">
          <actions>
            <do_if value="@$config.$syncStationProductionSettings == true">
              <set_value name="$oppositeConfig" exact="@player.entity.$productionStationsTab" />
              <do_if value="@$oppositeConfig != null">
                <set_value name="$syncableKeys" exact="['$ignoreNoResources', '$ignoreWaitStore', '$dataRefreshInterval']" />
                <do_if value="$syncableKeys.indexof.{$valueId} != 0">
                  <set_value name="$syncValue" exact="@$config.{@$valueId}" />
                  <set_value name="$oppositeConfig.{@$valueId}" exact="$syncValue" />
                  <remove_value name="$syncValue" />
                  <raise_lua_event name="'PST.ConfigChanged'" />
                </do_if>
                <remove_value name="$syncableKeys" />
              </do_if>
              <remove_value name="$oppositeConfig" />
            </do_if>
          </actions>
        </library>

        <!-- == Interoperability section == -->
        <library name="Menu_Section_Interoperability" purpose="include_actions" version="1">
          <actions>
            <include_actions ref="Add_Empty_Row" />
            <run_actions ref="Add_Title_Row">
              <param name="title" value="{1972092416, 90300}" />
            </run_actions>
            <set_value name="$oppositeConfig" exact="@player.entity.$productionStationsTab" />
            <run_actions ref="Add_CheckBox">
              <param name="id" value="'syncStationProductionSettings'" />
              <param name="col" value="1" />
              <param name="textColSpan" value="11" />
              <param name="text" value="{1972092416, 90301}" />
              <param name="data" value="@$config" />
              <param name="active" value="@$oppositeConfig != null" />
            </run_actions>
            <remove_value name="$oppositeConfig" />
          </actions>
        </library>

        <!-- == Interoperability sync handler == -->
        <!-- $config and sync flag already set by caller.                      -->
        <library name="Handle_Sync_Changed" purpose="include_actions" version="1">
          <actions>
            <set_value name="$oppositeConfig" exact="@player.entity.$productionStationsTab" />
            <do_if value="@$oppositeConfig != null">
              <do_if value="event.param.$checked">
                <!-- Enabling sync: copy settings from PST to SPO -->
                <set_value name="$oppositeConfig.$syncStationProductionSettings" exact="true" />
                <set_value name="$config.$dataRefreshInterval" exact="@$oppositeConfig.$dataRefreshInterval" />
                <set_value name="$config.$ignoreNoResources" exact="@$oppositeConfig.$ignoreNoResources" />
                <set_value name="$config.$ignoreWaitStore" exact="@$oppositeConfig.$ignoreWaitStore" />
                <signal_cue_instantly cue="md.Simple_Menu_API.Refresh_Menu" />
              </do_if>
              <do_else>
                <!-- Disabling sync: flag already cleared -->
                <set_value name="$oppositeConfig.$syncStationProductionSettings" exact="false" />
              </do_else>
              <raise_lua_event name="'PST.ConfigChanged'" />
            </do_if>
            <remove_value name="$oppositeConfig" />
          </actions>
        </library>

        <!-- == UI helper libraries (based on Notification Filter pattern) == -->

        <library name="Add_CheckBox" purpose="run_actions">
          <params>
            <param name="id" />
            <param name="col" default="1" />
            <param name="textColSpan" default="1" />
            <param name="text" default="''" />
            <param name="data" />
            <param name="active" default="true" />
          </params>
          <actions>
            <do_if value="@$id != null and $col? and $textColSpan? and @$text != null and @$data != null">
              <do_if value="@$col == 1">
                <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
              </do_if>
              <set_value name="$valueId" exact="'$%s' . [@$id]" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox"
                param="table[
                  $id      = 'SPO_CheckBox_%s' . [@$id],
                  $checked = @$data.{@$valueId} == true,
                  $col     = @$col,
                  $colSpan = 1,
                  $x       = 20,
                  $width   = 'Helper.standardButtonHeight',
                  $height  = 'Helper.standardButtonHeight',
                  $onClick = Handle_Checkbox_Changed,
                  $echo    = table[ $valueId = @$valueId ],
                  $active  = @$active,
                ]" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                param="table[
                  $col     = @$col + 1,
                  $colSpan = @$textColSpan,
                  $halign  = 'left',
                  $text    = @$text,
                ]" />
            </do_if>
          </actions>
        </library>

        <library name="Add_Slider" purpose="run_actions">
          <params>
            <param name="id" />
            <param name="text" default="''" />
            <param name="min" default="0" />
            <param name="max" default="100" />
            <param name="step" default="1" />
            <param name="suffix" default="''" />
            <param name="colSpan" default="12" />
            <param name="data" />
          </params>
          <actions>
            <do_if value="@$id != null and $min? and $max? and $step? and @$data != null">
              <set_value name="$valueId" exact="'$%s' . [@$id]" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
                param="table[
                  $col     = 1,
                  $colSpan = @$colSpan,
                  $halign  = 'left',
                  $text    = @$text,
                ]" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
              <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider"
                param="table[
                  $id                  = 'SPO_Slider_%s' . [@$id],
                  $col                 = 1,
                  $colSpan             = @$colSpan,
                  $min                 = @$min,
                  $max                 = @$max,
                  $step                = @$step,
                  $start               = @$data.{@$valueId},
                  $suffix              = @$suffix,
                  $onSliderCellConfirm = Handle_Slider_Changed,
                  $echo                = table[ $valueId = @$valueId ],
                ]" />
            </do_if>
          </actions>
        </library>

        <library name="Add_Title_Row" purpose="run_actions">
          <params>
            <param name="title" />
          </params>
          <actions>
            <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
            <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
              param="table[
                $col        = 1,
                $colSpan    = 12,
                $fontsize   = 'Helper.titleFontSize',
                $titleColor = 'Color.text_normal',
                $halign     = 'center',
                $text       = $title,
              ]" />
            <include_actions ref="Add_Empty_Row" />
          </actions>
        </library>

        <library name="Add_Empty_Row" purpose="include_actions">
          <actions>
            <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" param="table[$selectable = false]" />
            <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text"
              param="table[
                $col      = 1,
                $colSpan  = 12,
                $height   = 'Helper.borderSize',
                $fontsize = 'Helper.borderSize',
              ]" />
          </actions>
        </library>

      </cues>
    </cue>

  </cues>
</mdscript>